{
  "name": "ev-charging-station-api",
  "version": "1.0.0",
  "description": "Smart EV Charging Station Recommendation Backend API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b && node dist/server.js",
    "start": "node dist/server.js",
    "seed": "tsc -b && node dist/scripts/seed.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "ev",
    "charging",
    "station",
    "recommendation",
    "mongodb",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.0",
    "cors": "^2.8.6",
    "expo": "^54.0.33",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.5",
    "socket.io": "^4.8.3",
    "@types/express": "^5.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/node": "^25.0.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
